# ============================================================
# MADCreate — Environment Variables (TEMPLATE)
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. NEVER put real secrets in this file.
# ============================================================

# -------- Core --------
NODE_ENV=development
APP_NAME=MADCreate
APP_VERSION=0.1.0

# -------- URLs --------
APP_URL=http://localhost:3013
API_URL=http://localhost:4213
APP_PUBLIC_DOMAIN=madcreate.madprospects.com
API_PUBLIC_DOMAIN=madcreateapi.madprospects.com

# -------- API --------
API_PORT=4213
API_HOST=0.0.0.0
API_GLOBAL_PREFIX=v1
API_CORS_ORIGINS=http://localhost:3013,https://madcreate.madprospects.com

# -------- Web (Angular) --------
WEB_PORT=3013
WEB_API_BASE_URL=http://localhost:4213/v1

# -------- Platform SFTP deploy targets --------
# Used by `npm run deploy:web` / `npm run deploy:api` to ship the platform itself.
FRONTEND_SFTP_HOST=
FRONTEND_SFTP_PORT=22
FRONTEND_SFTP_USER=
FRONTEND_SFTP_PASS=
FRONTEND_REMOTE_PATH=

API_SFTP_HOST=
API_SFTP_PORT=22
API_SFTP_USER=
API_SFTP_PASS=
API_REMOTE_PATH=

# -------- Default tenant SFTP (used when a tenant deployment omits config) --------
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASS=
SFTP_KEY_PATH=
SFTP_REMOTE_PATH=

# -------- Local Database (for `docker compose up mysql`) --------
DATABASE_LOCAL_URL=mysql://madcreate:madcreate@localhost:3306/madcreate
MYSQL_LOCAL_ROOT_PASSWORD=changeme_root
MYSQL_LOCAL_DATABASE=madcreate
MYSQL_LOCAL_USER=madcreate
MYSQL_LOCAL_PASSWORD=madcreate
MYSQL_LOCAL_HOST=localhost
MYSQL_LOCAL_PORT=3306

# -------- Database (active connection used by Prisma) --------
# MUST be a full URL. URL-encode special chars in the password ('@' -> '%40').
# Format: mysql://USER:PASS@HOST:PORT/DB
DATABASE_URL=mysql://madcreate:madcreate@localhost:3306/madcreate
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=madcreate
MYSQL_USER=madcreate
MYSQL_PASSWORD=madcreate
MYSQL_HOST=localhost
MYSQL_PORT=3306

# -------- Redis --------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -------- JWT / Auth --------
JWT_SECRET=replace_me_with_a_long_random_string_min_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string
JWT_REFRESH_TTL=30d
PASSWORD_RESET_TTL=1h
EMAIL_VERIFICATION_TTL=24h
MAGIC_LINK_TTL=15m

# -------- Bootstrap Super Admin --------
DEFAULT_USER_EMAIL=admin@madprospects.com
DEFAULT_USER_PASSWORD=P@szw0rdMP
ADMIN_USER_EMAIL=admin@madprospects.com
ADMIN_USER_PASSWORD=P@szw0rdMP
PLATFORM_BOOTSTRAP_ADMIN_EMAIL=admin@madprospects.com
PLATFORM_BOOTSTRAP_ADMIN_PASSWORD=P@szw0rdMP

# -------- AI Providers --------
# MADCreate uses the `claude-code-manual` provider exclusively — it builds a
# self-contained prompt that the tenant runs in their own Claude Code session
# and pastes back via POST /v1/ai/generations/:id/submit. NO API keys required.

# -------- Email (SMTP) --------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MADCreate <no-reply@madcreate.madprospects.com>"

# -------- Storage / Media --------
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage/uploads
STORAGE_PUBLIC_URL=http://localhost:4213/media
# For S3-compatible (DigitalOcean Spaces, AWS S3, Cloudflare R2):
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# -------- Cloudflare (DNS auto-record + Pages deployment) --------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_PROJECT_NAME=

# -------- Vercel deploy adapter --------
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# -------- DigitalOcean deploy adapter --------
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_APP_ID=

# -------- Docker deploy adapter (requires `docker` CLI on the API host) --------
DOCKER_IMAGE=
DOCKER_BASE_IMAGE=nginx:1.27-alpine
DOCKER_REGISTRY_USER=
DOCKER_REGISTRY_PASS=

# -------- Plain FTP (separate from SFTP above) --------
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASS=
FTP_REMOTE_PATH=

# -------- Integrations (placeholders, filled per tenant later) --------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# -------- Observability --------
LOG_LEVEL=info
LOG_PRETTY=true
SENTRY_DSN=

# -------- Feature flags --------
FEATURE_AI_GENERATION=true
FEATURE_VISUAL_BUILDER=true
FEATURE_CUSTOM_DOMAINS=true
FEATURE_BILLING=false
