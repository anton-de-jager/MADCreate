// MADCreate — Prisma schema
// Multi-tenant SaaS data model for AI-native site & app generation.
// Conventions:
//   - cuid() ids
//   - createdAt / updatedAt timestamps on every model
//   - soft delete via deletedAt (null = live)
//   - tenantId on every tenant-scoped row, with composite index (tenantId, ...)
//   - JSON columns for flexible AI-generated structures
// ---------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  WORKSPACE_OWNER
  ADMIN
  EDITOR
  VIEWER
  CLIENT
}

enum WorkspaceMemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum SiteStatus {
  DRAFT
  GENERATING
  READY
  PUBLISHED
  ARCHIVED
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DomainStatus {
  PENDING
  VERIFYING
  ACTIVE
  FAILED
  DISABLED
}

enum DomainType {
  SUBDOMAIN     // e.g. acme.madcreate.madleads.ai (auto-issued)
  APEX          // e.g. acme.com (A record)
  CNAME         // e.g. www.acme.com
  WILDCARD      // e.g. *.acme.com
}

enum DeploymentStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
  ROLLED_BACK
}

enum DeploymentTarget {
  INTERNAL          // hosted on the platform itself
  STATIC_EXPORT
  FTP
  SFTP
  DOCKER
  CLOUDFLARE_PAGES
  VERCEL
  DIGITAL_OCEAN
  CUSTOM_WEBHOOK
}

enum AIProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
  CUSTOM
  CLAUDE_CODE_MANUAL
  MOCK
}

enum AIGenerationKind {
  SITE
  PAGE
  SECTION
  COPY
  THEME
  PALETTE
  TYPOGRAPHY
  IMAGE_PROMPT
  SEO
  SCHEMA
  WORKFLOW
}

enum AIGenerationStatus {
  QUEUED
  RUNNING
  AWAITING_INPUT
  SUCCESS
  FAILED
}

enum MediaKind {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  FONT
  ICON
  OTHER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PUBLISH
  GENERATE
  DEPLOY
  INVITE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum IntegrationCategory {
  PAYMENT
  CRM
  MARKETING
  EMAIL
  SMS_VOICE
  SOCIAL
  ADS
  AUTH
  DOCUMENTS
  SUPPORT
  ECOMMERCE
  SHIPPING
  CMS
  SEARCH
  CLOUD
  AI
  VECTOR
  AGENT
  MEDIA
  HR
  LEGAL
  MAPS
  COMMUNICATION
  PRODUCTIVITY
  ACCOUNTING
  AUTOMATION
  ANALYTICS
  CALENDAR
  STORAGE
  OTHER
}

enum AnalyticsEventKind {
  PAGE_VIEW
  CLICK
  FORM_SUBMIT
  CONVERSION
  AI_GENERATION
  DEPLOYMENT
  CUSTOM
}

enum TemplateVisibility {
  PRIVATE
  WORKSPACE
  PUBLIC
}

// ============================================================
// IDENTITY
// ============================================================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiedAt DateTime?
  passwordHash    String?
  firstName       String?
  lastName        String?
  avatarUrl       String?
  phone           String?
  locale          String    @default("en")
  timezone        String    @default("UTC")
  isSuperAdmin    Boolean   @default(false)
  lastLoginAt     DateTime?
  lastLoginIp     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships         WorkspaceMember[]
  refreshTokens       RefreshToken[]
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]
  magicLinks          MagicLink[]
  auditLogs           AuditLog[]
  uploadedMedia       Media[]            @relation("MediaUploader")
  aiGenerations       AIGeneration[]     @relation("AIGenerationRequester")

  @@index([deletedAt])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  userAgent String?   @db.Text
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model MagicLink {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  redirect  String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ============================================================
// MULTI-TENANCY
// ============================================================

// Workspace = a customer / company account in MADCreate.
// Tenant    = a deployable site/app belonging to a workspace.
// One workspace can own many tenants (multi-site agencies).
model Workspace {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  logoUrl     String?
  description String? @db.Text
  ownerUserId String

  // Billing
  planId             String?
  plan               Plan?               @relation(fields: [planId], references: [id])
  subscription       Subscription?
  trialEndsAt        DateTime?
  billingEmail       String?

  // Settings
  defaultLocale  String  @default("en")
  defaultTimezone String @default("UTC")
  settings       Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  members   WorkspaceMember[]
  tenants   Tenant[]
  invites   WorkspaceInvite[]
  templates Template[]
  auditLogs AuditLog[]
  apiKeys   ApiKey[]
  featureFlags FeatureFlag[]

  @@index([deletedAt])
  @@index([planId])
}

model WorkspaceMember {
  id          String                @id @default(cuid())
  workspaceId String
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role                  @default(EDITOR)
  status      WorkspaceMemberStatus @default(ACTIVE)
  invitedAt   DateTime              @default(now())
  joinedAt    DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId, role])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        Role      @default(EDITOR)
  tokenHash   String    @unique
  invitedById String
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([workspaceId, email])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  prefix      String    // first 8 chars shown in UI
  hash        String    @unique
  scopes      Json      // string[] of scopes
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

// Tenant = the unit of deployment (one tenant === one site / app).
// Many models hang off tenantId for fast isolation.
model Tenant {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug        String    @unique          // becomes /:slug on the platform root
  name        String
  description String?   @db.Text
  industry    String?
  status      SiteStatus @default(DRAFT)

  // Onboarding answers persisted as flexible JSON; the wizard reads/writes these.
  onboarding  Json?
  branding    Json?     // colors, logo refs, typography, voice

  // Pointers to "current" published artefacts
  activeSiteId  String?
  activeThemeId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sites          Site[]
  pages          Page[]
  sections       Section[]
  layouts        Layout[]
  themes         Theme[]
  domains        Domain[]
  deployments    Deployment[]
  integrations   TenantIntegration[]
  aiGenerations  AIGeneration[]
  media          Media[]
  analyticsEvents AnalyticsEvent[]
  environments   Environment[]
  forms          FormSubmission[]
  leads          Lead[]

  @@index([workspaceId])
  @@index([slug])
  @@index([deletedAt])
}

model Environment {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String  // dev / staging / prod
  variables Json    // KV map (secrets redacted in transit)
  isDefault Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([tenantId, name])
}

// ============================================================
// SITE / CONTENT MODEL
// ============================================================

model Site {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  status      SiteStatus  @default(DRAFT)
  version     Int         @default(1)
  themeId     String?
  theme       Theme?      @relation(fields: [themeId], references: [id])
  navigation  Json?       // ordered nav config
  settings    Json?       // SEO defaults, favicon, og defaults, scripts
  publishedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  pages       Page[]
  deployments Deployment[]

  @@index([tenantId, status])
  @@index([themeId])
}

model Page {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId    String
  site      Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  layoutId  String?
  layout    Layout?    @relation(fields: [layoutId], references: [id])
  slug      String     // unique per site
  title     String
  metaTitle String?
  metaDescription String? @db.Text
  ogImageUrl String?
  status    PageStatus @default(DRAFT)
  order     Int        @default(0)
  schema    Json       // full page JSON (sections, props, content)
  publishedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sections Section[]

  @@unique([siteId, slug])
  @@index([tenantId, status])
  @@index([layoutId])
}

model Layout {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  schema   Json   // header, footer, sidebar slots
  isDefault Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  pages Page[]

  @@index([tenantId])
}

model Section {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pageId   String?
  page     Page?   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  kind     String  // "hero" | "features" | "pricing" | "cta" | "faq" | ...
  name     String?
  order    Int     @default(0)
  props    Json
  reusableKey String? // if non-null, this is a library section

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId, pageId])
  @@index([reusableKey])
}

model Theme {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  tokens     Json    // design tokens (colors, spacing, typography, radius, shadow, motion)
  isActive   Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sites Site[]

  @@index([tenantId, isActive])
}

model Template {
  id          String             @id @default(cuid())
  workspaceId String?
  workspace   Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name        String
  slug        String             @unique
  description String?            @db.Text
  category    String?            // landing / dashboard / church / medical / ...
  industry    String?
  previewUrl  String?
  thumbnailUrl String?
  visibility  TemplateVisibility @default(PRIVATE)
  schema      Json               // full site schema clonable into a tenant
  popularity  Int                @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([category])
  @@index([visibility])
}

// ============================================================
// DOMAINS
// ============================================================

model Domain {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hostname      String       @unique
  type          DomainType
  status        DomainStatus @default(PENDING)
  isPrimary     Boolean      @default(false)
  verifyToken   String?
  lastCheckedAt DateTime?
  lastError     String?      @db.Text
  sslStatus     String?      // 'none' | 'pending' | 'active' | 'failed'
  sslIssuedAt   DateTime?
  sslExpiresAt  DateTime?
  cloudflareId  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId])
  @@index([status])
}

// ============================================================
// DEPLOYMENTS
// ============================================================

model Deployment {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  siteId      String?
  site        Site?            @relation(fields: [siteId], references: [id], onDelete: SetNull)
  target      DeploymentTarget
  status      DeploymentStatus @default(PENDING)
  triggeredBy String?          // userId
  config      Json?            // target-specific config snapshot
  log         String?          @db.LongText
  artefactUrl String?
  startedAt   DateTime?
  finishedAt  DateTime?
  durationMs  Int?
  version     String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([siteId])
}

// ============================================================
// INTEGRATIONS
// ============================================================

// IntegrationCatalog = the global registry of available integrations.
// TenantIntegration  = an installed instance for a specific tenant.
model IntegrationCatalog {
  id          String              @id @default(cuid())
  key         String              @unique  // 'stripe' | 'whatsapp' | 'xero' | ...
  name        String
  category    IntegrationCategory
  description String?             @db.Text
  iconUrl     String?
  configSchema Json?              // JSON Schema describing required config
  isEnabled   Boolean             @default(true)
  popular     Boolean             @default(false)  // shown in the "Popular" row of the onboarding wizard

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  installs TenantIntegration[]
}

model TenantIntegration {
  id             String             @id @default(cuid())
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  catalogId      String
  catalog        IntegrationCatalog @relation(fields: [catalogId], references: [id])
  config         Json               // encrypted/redacted secrets in transit
  isEnabled      Boolean            @default(true)
  lastSyncedAt   DateTime?
  lastError      String?            @db.Text

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([tenantId, catalogId])
  @@index([tenantId])
}

// ============================================================
// AI
// ============================================================

model AIPrompt {
  id          String           @id @default(cuid())
  key         String           @unique     // 'generate.page', 'generate.section.hero', ...
  name        String
  description String?          @db.Text
  kind        AIGenerationKind
  provider    AIProvider
  model       String
  systemPrompt String          @db.LongText
  userTemplate String          @db.LongText // mustache/handlebars-style template
  schema      Json?            // expected JSON-schema output shape
  temperature Float?           @default(0.7)
  maxTokens   Int?
  isActive    Boolean          @default(true)
  version     Int              @default(1)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  generations AIGeneration[]
}

model AIGeneration {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requesterId String?
  requester   User?              @relation("AIGenerationRequester", fields: [requesterId], references: [id], onDelete: SetNull)
  promptId    String?
  prompt      AIPrompt?          @relation(fields: [promptId], references: [id])
  kind        AIGenerationKind
  provider    AIProvider
  model       String
  status      AIGenerationStatus @default(QUEUED)
  input       Json               // request payload (variables for template)
  output      Json?              // parsed JSON result
  rawOutput   String?            @db.LongText
  tokensIn    Int?
  tokensOut   Int?
  costUsd     Decimal?           @db.Decimal(10, 6)
  durationMs  Int?
  error       String?            @db.Text
  startedAt   DateTime?
  finishedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([kind])
  @@index([createdAt])
}

// ============================================================
// MEDIA
// ============================================================

model Media {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploaderId   String?
  uploader     User?     @relation("MediaUploader", fields: [uploaderId], references: [id], onDelete: SetNull)
  kind         MediaKind
  filename     String
  contentType  String
  sizeBytes    Int
  width        Int?
  height       Int?
  durationMs   Int?
  url          String    @db.Text
  storageKey   String?
  thumbnailUrl String?   @db.Text
  altText      String?
  tags         Json?     // string[]
  meta         Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId, kind])
}

// ============================================================
// ANALYTICS / LEADS / FORMS
// ============================================================

model AnalyticsEvent {
  id        String              @id @default(cuid())
  tenantId  String
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind      AnalyticsEventKind
  pageSlug  String?
  userKey   String?             // anonymous visitor key
  sessionKey String?
  referrer  String?             @db.Text
  userAgent String?             @db.Text
  ip        String?
  country   String?
  payload   Json?
  occurredAt DateTime           @default(now())

  @@index([tenantId, kind, occurredAt])
  @@index([tenantId, pageSlug, occurredAt])
}

model FormSubmission {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  formKey    String
  pageSlug   String?
  data       Json
  ip         String?
  userAgent  String?   @db.Text
  spamScore  Float?

  createdAt DateTime @default(now())

  @@index([tenantId, formKey, createdAt])
}

model Lead {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email      String?
  phone      String?
  name       String?
  source     String?
  status     String   @default("new")
  data       Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tenantId, status, createdAt])
}

// ============================================================
// AUDIT
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String?
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  tenantId    String?
  userId      String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      AuditAction
  entity      String      // 'site' | 'page' | 'domain' | ...
  entityId    String?
  before      Json?
  after       Json?
  meta        Json?
  ip          String?
  userAgent   String?     @db.Text

  createdAt DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([tenantId, createdAt])
  @@index([entity, entityId])
}

// ============================================================
// BILLING
// ============================================================

model Plan {
  id              String          @id @default(cuid())
  code            String          @unique  // 'free' | 'starter' | 'growth' | 'scale' | 'enterprise'
  name            String
  description     String?         @db.Text
  isPublic        Boolean         @default(true)
  priceMonthlyUsd Decimal         @db.Decimal(10, 2)
  priceAnnualUsd  Decimal         @db.Decimal(10, 2)
  trialDays       Int             @default(14)
  limits          Json            // tenants, sites, ai_tokens_per_month, deployments_per_month, custom_domains, members
  features        Json            // string[] feature keys
  sortOrder       Int             @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  workspaces    Workspace[]
  subscriptions Subscription[]
}

model Subscription {
  id                String              @id @default(cuid())
  workspaceId       String              @unique
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planId            String
  plan              Plan                @relation(fields: [planId], references: [id])
  status            SubscriptionStatus  @default(TRIALING)
  interval          BillingInterval     @default(MONTHLY)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  cancelledAt        DateTime?
  externalCustomerId String?            // stripe customer id
  externalSubscriptionId String?        // stripe subscription id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([planId])
}

// ============================================================
// FEATURE FLAGS
// ============================================================

model FeatureFlag {
  id          String     @id @default(cuid())
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key         String
  enabled     Boolean    @default(false)
  payload     Json?
  description String?    @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, key])
  @@index([key])
}

// ============================================================
// CLAUDE TASK QUEUE — admin / worker hand-off
// A separate Claude Code session polls /api/claude-tasks/next; this is the
// operator's window into the queue. NOT scoped per-tenant.
// ============================================================

enum ClaudeTaskStatus {
  PENDING
  IN_PROGRESS
  TO_BE_DEPLOYED
  COMPLETED
  CANCELLED
  FAILED
  DEFERRED
}

model ClaudeTask {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(300)
  description String?  @db.Text
  notes       String?  @db.Text
  status      ClaudeTaskStatus @default(PENDING)
  priority    Int      @default(3) // 1=critical, 2=high, 3=normal, 4=low
  attachments Json?    // ClaudeTaskAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, priority, id])
}

model ClaudePromptTemplate {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(200)
  description String?  @db.Text
  content     String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}
