# Setup.xlsx deploy values - local secrets, do not commit
# MADCreate deploy credentials.
# ──────────────────────────────────────────────────────────────
# THIS FILE IS .gitignored. Do NOT commit.
# Rotate passwords here; deploy.ps1 loads this at startup so
# changes take effect on the next ./deploy.ps1 run.
#
# NOTE: the parser does NOT strip inline `# comments` after a
# value. Keep all comments on their own lines.
# ──────────────────────────────────────────────────────────────

# Public URLs the SPA + API are served at.
FRONTEND_PUBLIC_URL=https://madcreate.madprospects.com
API_PUBLIC_URL=https://madcreateapi.madprospects.com

# Frontend (DreamHost CloudCompute, Apache static vhost)
FRONTEND_SFTP_HOST=41.185.110.61
FRONTEND_SFTP_USER=madprospects
FRONTEND_SFTP_PASS=Mi@dJ111
FRONTEND_REMOTE_PATH=/home/madprospects/madcreate.madprospects.com

# API (DreamHost CloudCompute, PM2 process behind Apache reverse-proxy)
# API_REMOTE_PATH: PM2 app dir (OUTSIDE the Apache web root)
# API_WEB_ROOT   : Apache web root (.htaccess lands here)
# API_PORT       : upstream PM2 port (multisciple/mh-api use 3002 on this box)
API_SFTP_HOST=41.185.110.61
API_SFTP_USER=madprospects
API_SFTP_PASS=Mi@dJ111
API_REMOTE_PATH=/home/madprospects/madcreateapi
API_WEB_ROOT=/home/madprospects/madcreateapi.madprospects.com
API_PORT=3005
PM2_PROCESS_NAME=mc-api

# MYSQL (DreamHost managed → mysql.madcreate.madleads.ai)
DB_HOST=mysql.madcreate.madleads.ai
DB_PORT=3306
DB_USERNAME=madcreate
DB_PASSWORD=Mi@dJ111
DB_DATABASE=madcreate

# Bootstrap super-admin. Change DEFAULT_USER_PASSWORD immediately
# after the first -Seed deploy via /app/settings in the browser.
DEFAULT_USER_EMAIL=admin@madprospects.com
DEFAULT_USER_PASSWORD=P@szw0rdMP

# Optional — defaults to FRONTEND_PUBLIC_URL. Comma-separated for multiple origins.
# CORS_ORIGINS=https://madcreate.madprospects.com,https://staging.madcreate.madprospects.com

# Optional — defaults to redis://127.0.0.1:6379. Override if Redis is not
# running on the CloudCompute box itself.
# REDIS_URL=redis://127.0.0.1:6379
CLAUDE_WORKER_TOKEN=4d260e4cee6be56fcac5fc668e7c942d5daf8ee2f4005f4616d241c3753fede5

