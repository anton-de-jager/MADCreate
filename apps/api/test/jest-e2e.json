{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@madcreate/shared$": "<rootDir>/../../packages/shared/src",
    "^@env/(.*)$": "<rootDir>/src/config/$1"
  },
  "testEnvironment": "node",
  "setupFilesAfterSetup": ["./test/setup-e2e.ts"],
  "testTimeout": 30000
}
